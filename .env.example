# =============================================================
# AssetFlow — Environment Variables Example
# Copy this file to .env and fill in your values.
# Both services (core-api and reports-api) read from this file.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=optusyes523
POSTGRES_DB=assetflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full connection strings (used directly by each service)
DATABASE_URL=postgresql+asyncpg://postgres:optusyes523@localhost:5432/assetflow_db
REPORTS_DATABASE_URL=postgresql+psycopg2://postgres:optusyes523@localhost:5432/assetflow_db

# ── Auth ──────────────────────────────────────────────────────
# Shared secret — MUST be identical in both services
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Service Ports ─────────────────────────────────────────────
CORE_API_PORT=8000
REPORTS_API_PORT=8001

# ── Frontend (used by Vite dev proxy, not a backend var) ──────
VITE_CORE_API_URL=http://localhost:8000
VITE_REPORTS_API_URL=http://localhost:8001

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
